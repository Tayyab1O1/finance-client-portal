rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Admins can upload/read client logos and covers; clients can only read their own
    match /clients/{clientId}/{fileName} {
      allow read: if request.auth != null &&
        (isAdmin() ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.clientId == clientId);
      allow write: if isAdmin() && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
